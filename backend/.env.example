# 后端配置文件路径（默认 config/config.dev.yaml）
CONFIG_FILE=config/config.dev.yaml

# 依赖镜像（开发机建议）
GOPROXY=https://goproxy.cn,direct

# 可选：临时覆盖部分配置项（优先级高于配置文件）
# HTTP_ADDR=:8080
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=123456
# MYSQL_DATABASE=myapp
# REDIS_ADDR=127.0.0.1:6379
# REDIS_PASSWORD=
# REDIS_DB=0
# JWT_SECRET=change-me
# ADMIN_SEED_ENABLED=true
# ADMIN_SEED_USERNAME=admin
# ADMIN_SEED_PASSWORD=Admin@123456
# ADMIN_SEED_DISPLAY_NAME=Administrator
# ADMIN_SEED_EMAIL=admin@kbmanage.local
# CORS_ALLOW_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-Id
# CORS_EXPOSE_HEADERS=X-Request-Id
# CORS_ALLOW_CREDENTIALS=true
# CORS_MAX_AGE_SECONDS=600
# CREDENTIAL_CIPHER_KEY=change-me-credential-key
