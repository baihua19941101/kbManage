# 前端应用展示名
VITE_APP_NAME=kbManage

# 后端 API 基础路径
VITE_API_BASE_URL=/api/v1
# 可观测、工作负载运维、GitOps 与发布中心模块均复用同一 API 前缀

# Vite 开发服务器监听配置
# 启动端口必须通过 VITE_PORT 配置，不要在脚本中硬编码端口
VITE_HOST=0.0.0.0
VITE_PORT=5173

# GitOps 页面轮询与刷新（毫秒）
VITE_GITOPS_OPERATION_POLL_INTERVAL=5000
VITE_GITOPS_DIFF_REFRESH_INTERVAL=15000
