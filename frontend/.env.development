# 开发环境默认配置，可按本机环境调整
# 本地开发默认前端端口（与 README 启动说明一致）
# 可观测、工作负载运维、GitOps 与发布中心模块均复用 VITE_API_BASE_URL
VITE_APP_NAME=kbManage
VITE_API_BASE_URL=http://localhost:8888/api/v1
VITE_HOST=0.0.0.0
VITE_PORT=5000

# GitOps 页面轮询与刷新（毫秒）
VITE_GITOPS_OPERATION_POLL_INTERVAL=5000
VITE_GITOPS_DIFF_REFRESH_INTERVAL=15000

# 安全策略页面刷新（毫秒）
VITE_SECURITY_POLICY_REFRESH_INTERVAL=10000

# 合规与加固页面刷新（毫秒）
VITE_COMPLIANCE_REFRESH_INTERVAL=10000

# 集群生命周期页面刷新（毫秒）
VITE_CLUSTER_LIFECYCLE_REFRESH_INTERVAL=10000

# 备份恢复与灾备页面刷新（毫秒）
VITE_BACKUP_RESTORE_REFRESH_INTERVAL=10000

# 身份与多租户治理页面刷新（毫秒）
VITE_IDENTITY_TENANCY_REFRESH_INTERVAL=10000

# 平台应用目录与扩展市场页面刷新（毫秒）
VITE_PLATFORM_MARKETPLACE_REFRESH_INTERVAL=10000

# 平台 SRE 与规模化治理页面刷新（毫秒）
VITE_SRE_SCALE_REFRESH_INTERVAL=10000
